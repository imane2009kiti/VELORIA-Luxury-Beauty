                    <button class="faq-question">
                        ${faq.q}
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>${faq.a}</p>
                    </div>
                `;
                faqContainer.appendChild(item);
            });

            // FAQ Accordion Logic
            document.querySelectorAll('.faq-question').forEach(button => {
                button.addEventListener('click', () => {
                    const item = button.parentNode;
                    const answer = button.nextElementSibling;
                    const isActive = item.classList.contains('active');
                    
                    document.querySelectorAll('.faq-item').forEach(el => {
                        el.classList.remove('active');
                        el.querySelector('.faq-answer').style.maxHeight = null;
                        el.querySelector('.faq-icon').textContent = '+';
                    });

                    if (!isActive) {
                        item.classList.add('active');
                        answer.style.maxHeight = answer.scrollHeight + "px";
                        button.querySelector('.faq-icon').textContent = '×';
                    }
                });
            });

            // 2. DYNAMIC TABLE OF CONTENTS
            const tocList = document.getElementById('toc-list');
            const headings = document.querySelectorAll('.main-content h2');
            const observerOptions = { root: null, rootMargin: '0px 0px -80% 0px', threshold: 0 };
            
            let activeLink = null;

            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        if (activeLink) activeLink.classList.remove('active');
                        const id = entry.target.getAttribute('id');
                        activeLink = document.querySelector(`.toc-list a[href="#${id}"]`);
                        if (activeLink) activeLink.classList.add('active');
                    }
                });
            }, observerOptions);

            headings.forEach(heading => {
                if (!heading.id) return;
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = `#${heading.id}`;
                a.textContent = heading.textContent;
                li.appendChild(a);
                tocList.appendChild(li);
                observer.observe(heading);
            });

            // 3. READING PROGRESS BAR
            window.addEventListener('scroll', () => {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = (winScroll / height) * 100;
                document.getElementById('reading-progress').style.width = scrolled + "%";
            });

            // 4. INJECT SEO SCHEMA (JSON-LD)
            const schemaData = {
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "Article",
                        "headline": CONFIG.articleTitle,
                        "description": CONFIG.seoDescription,
                        "author": { "@type": "Person", "name": CONFIG.authorName },
                        "datePublished": "2026-10-20",
                        "dateModified": "2026-10-24"
                    },
                    {
                        "@type": "Product",
                        "name": CONFIG.productName,
                        "image": CONFIG.imgProduct,
                        "description": CONFIG.seoDescription,
                        "offers": {
                            "@type": "Offer",
                            "priceCurrency": "USD",
                            "price": CONFIG.productPrice.replace('$', ''),
                            "url": CONFIG.affiliateLink
                        },
                        "aggregateRating": {
                            "@type": "AggregateRating",
                            "ratingValue": CONFIG.productRating,
                            "reviewCount": CONFIG.reviewCount.replace(',', '')
                        }
                    },
                    {
                        "@type": "FAQPage",
                        "mainEntity": CONFIG.faqs.map(faq => ({
                            "@type": "Question",
                            "name": faq.q,
                            "acceptedAnswer": { "@type": "Answer", "text": faq.a }
                        }))
                    }
                ]
            };
            document.getElementById('schema-data').textContent = JSON.stringify(schemaData);
        });
    </script>
</body>
</html>
